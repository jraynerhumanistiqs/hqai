{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "HQ.ai Option 1 - Current (Uber-aligned, parent-brand consistent)",
  "version": "v3.0",
  "extractedFrom": "hqai/tailwind.config.ts + hqai/globals.css + hqai/DESIGN-uber.md",
  "intent": "Stay-the-same baseline. Parent-brand (Humanistiqs) aligned, pure achromatic, maximum trust signal for SMB owners who want zero design noise.",
  "color": {
    "brand": {
      "black":    { "value": "#000000", "role": "primary CTA, headings, nav text, sidebar bg" },
      "white":    { "value": "#FFFFFF", "role": "page bg, card surface, inverse text" }
    },
    "text": {
      "charcoal": { "value": "#1F1F1F", "role": "deepest text on dark surfaces" },
      "mid":      { "value": "#4B4B4B", "role": "secondary body text" },
      "muted":    { "value": "#AFAFAF", "role": "tertiary, placeholder" }
    },
    "surface": {
      "bg":       { "value": "#FFFFFF", "role": "page background" },
      "light":    { "value": "#EFEFEF", "role": "chip / filter bg" },
      "border":   { "value": "#E2E2E2", "role": "dividers, input border" }
    },
    "accent": {
      "accent":   { "value": "#000000", "role": "primary CTA (= black)" },
      "accent2":  { "value": "#1A1A1A", "role": "CTA hover" },
      "accent3":  { "value": "#EFEFEF", "role": "chip / pill bg" }
    },
    "semantic": {
      "danger":   { "value": "#D94F4F" },
      "warning":  { "value": "#C8850A" },
      "success":  { "value": "#3D8A5E" }
    }
  },
  "typography": {
    "family": {
      "sans":    "DM Sans, sans-serif",
      "display": "DM Sans, sans-serif",
      "serif":   "DM Sans, sans-serif",
      "mono":    "system-ui monospace fallback"
    },
    "weight": { "regular": 400, "medium": 500, "bold": 700 },
    "scale": {
      "display": { "size": "52px", "lineHeight": 1.23, "letterSpacing": "-0.01em" },
      "h1":      { "size": "36px", "lineHeight": 1.22, "letterSpacing": "-0.01em" },
      "h2":      { "size": "32px", "lineHeight": 1.25, "letterSpacing": "-0.01em" },
      "h3":      { "size": "24px", "lineHeight": 1.33 },
      "body":    { "size": "16px", "lineHeight": 1.50 },
      "small":   { "size": "14px", "lineHeight": 1.43 },
      "xs":      { "size": "12px", "lineHeight": 1.67 }
    }
  },
  "radius": {
    "sm":   "4px",
    "md":   "8px",
    "lg":   "12px",
    "xl":   "16px",
    "2xl":  "20px",
    "pill": "9999px"
  },
  "shadow": {
    "card":  "0 4px 16px rgba(0,0,0,0.12)",
    "float": "0 2px 8px rgba(0,0,0,0.16)",
    "modal": "0 8px 40px rgba(0,0,0,0.18)",
    "cmd":   "0 32px 80px rgba(0,0,0,0.2)"
  },
  "spacing": {
    "base": "4px",
    "scale": ["4px","8px","12px","16px","20px","24px","32px","40px","48px","64px","96px"],
    "sidebar": "248px"
  },
  "motion": {
    "easing": { "smooth": "cubic-bezier(0.16, 1, 0.3, 1)" },
    "duration": { "fast": "150ms", "base": "200ms", "slow": "250ms" }
  },
  "darkMode": "Not implemented. Sidebar is the only persistently dark surface (#000000).",
  "wcag": "AA met for body text on white via #4B4B4B (>=7:1). #AFAFAF muted text on white = 2.6:1, FAILS 4.5:1; restrict to non-essential placeholders only."
}
