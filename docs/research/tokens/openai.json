    }
  },
  "radius": {
    "pill":      "9999px",
    "card":      "6.08px",
    "softButton":"40px",
    "link":      "4px"
  },
  "shadow": {
    "ctaOnly": "rgba(0,0,0,0.02) 0px 4px 6px, rgba(0,0,0,0.05) 0px 0px 2px"
  },
  "spacing": { "base": "4px", "scale": ["4","8","12","16","20","24","32","40","52","64","80","112","120"], "sectionGap": "64-80px", "cardPadding": "32px" },
  "layout": { "maxWidth": "1200px" }
}
